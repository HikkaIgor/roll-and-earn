{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "noEmitOnError": true,
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["tests/**/*.ts", "migrations/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
